# MongoDB Connection
MONGO_URI=mongodb://127.0.0.1:27017/campusRideDb

# JWT Secret for token signing (change in production)
JWT_SECRET=your_secure_secret_key_here

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Default seeded admin account
DEFAULT_ADMIN_NAME=Admin Boss
DEFAULT_ADMIN_EMAIL=admin@nu.edu.pk
DEFAULT_ADMIN_PASSWORD=admin

# Demo seeded admin account
DEMO_ADMIN_NAME=Demo Admin
DEMO_ADMIN_EMAIL=demo.admin@nu.edu.pk
DEMO_ADMIN_PASSWORD=demoadmin
